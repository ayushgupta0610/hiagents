# ===== hiagents environment (SaaS / multi-tenant mode) =====
#
# Everything below is DEPLOYMENT-LEVEL. Per-tenant configuration (persona,
# models, classifier prompt, similarity threshold, top-k, auto-send, daily
# email cap, etc.) lives in the `tenants.settings` JSONB column and is
# edited via the Settings UI per tenant.

# --- Server ---
PORT=3000
NODE_ENV=production
BASE_URL=https://bot.example.com
# DOMAIN is consumed by docker-compose / Caddy, not by the Node app.
DOMAIN=bot.example.com

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- OpenRouter (chat + embeddings, shared across all tenants) ---
OPENROUTER_API_KEY=sk-or-...

# --- Google OAuth (one app, all tenants OAuth through it) ---
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://bot.example.com/oauth/callback

# --- Admin / session ---
# Anyone with a Google account can sign in; tenants auto-provision on first
# signin. There is no password fallback — Google sign-in is the only way in.
# Access to specific workspaces is gated by the `memberships` table.

# SESSION_SECRET signs the admin session cookie (HMAC-SHA256). 32+ chars.
# Rotating this invalidates every active session.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# TOKEN_ENCRYPTION_KEY encrypts OAuth refresh + access tokens at rest
# (AES-256-GCM). 32 bytes, base64-encoded (≥40 chars). Rotating breaks
# decryption of existing tokens — users will need to re-connect Gmail.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=change-me-base64-encoded-32-byte-key

# --- Poller cadence (applies to every tenant) ---
POLL_INTERVAL_SECONDS=60

# --- Support contact (optional) ---
# Shown on user-facing OAuth error pages so failing users have someone to
# email when things go wrong. If unset, the "contact us" sentences are
# omitted entirely (no broken mailto links).
SUPPORT_EMAIL=
