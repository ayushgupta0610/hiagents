# ===== inbox-ai environment =====

# --- Server ---
PORT=3000
NODE_ENV=production
BASE_URL=https://bot.example.com
DOMAIN=bot.example.com

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- OpenRouter (for classifier + reply generation) ---
OPENROUTER_API_KEY=sk-or-...
CLASSIFIER_MODEL=openai/gpt-4o-mini
REPLY_MODEL=deepseek/deepseek-v4-flash

# --- Gmail OAuth ---
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://bot.example.com/oauth/callback
GMAIL_ADDRESS=you@yourdomain.com

# --- Admin UI ---
# ADMIN_PASSWORD doubles as the HMAC secret for signing session cookies AND as a
# fallback password login. Use a long random string even if you only use Google sign-in.
ADMIN_PASSWORD=change-me-to-a-long-random-string

# Note: in the multi-tenant SaaS build, ADMIN_EMAILS is replaced by the
# `memberships` table. Anyone with a Google account can sign in and they
# get auto-provisioned a tenant. See docs/ONBOARDING-FLOW.md.

# --- Tuning ---
SIMILARITY_THRESHOLD=0.7
TOP_K=5
POLL_INTERVAL_SECONDS=60

# --- Persona ---
SIGNATURE=— Sent by your AI assistant
TONE=professional, warm, concise
COMPANY_DESCRIPTION=Your company description (e.g. "AI Agency Corp, helping companies ship AI features faster")
