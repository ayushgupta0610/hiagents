# ===== inbox-ai environment (SaaS / multi-tenant mode) =====
#
# Everything below is DEPLOYMENT-LEVEL. Per-tenant configuration (persona,
# models, classifier prompt, similarity threshold, top-k, auto-send, daily
# email cap, etc.) lives in the `tenants.settings` JSONB column and is
# edited via the Settings UI per tenant.

# --- Server ---
PORT=3000
NODE_ENV=production
BASE_URL=https://bot.example.com
# DOMAIN is consumed by docker-compose / Caddy, not by the Node app.
DOMAIN=bot.example.com

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- OpenRouter (chat + embeddings, shared across all tenants) ---
OPENROUTER_API_KEY=sk-or-...

# --- Google OAuth (one app, all tenants OAuth through it) ---
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://bot.example.com/oauth/callback

# --- Admin ---
# ADMIN_PASSWORD doubles as the HMAC secret for signing session cookies AND
# as the fallback password login. Use a long random string. Anyone with a
# Google account can sign up — there is no global allowlist anymore (tenants
# auto-provision on first signin; access is gated by the `memberships` table).
ADMIN_PASSWORD=change-me-to-a-long-random-string

# --- Poller cadence (applies to every tenant) ---
POLL_INTERVAL_SECONDS=60
