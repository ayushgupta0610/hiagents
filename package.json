{
  "name": "hiagents",
  "version": "1.0.0",
  "description": "hiagents — AI agents that ship real work. Inbox is the first: a Gmail-native auto-reply grounded in your knowledge base.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/ui','dist/ui',{recursive:true})\"",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ai",
    "agents",
    "gmail",
    "rag",
    "pgvector",
    "supabase",
    "openrouter",
    "email-automation",
    "multi-tenant"
  ],
  "author": "Ayush Gupta",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "undici": "^8.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.0",
    "@types/pdf-parse": "^1.1.5",
    "@vitest/coverage-v8": "^4.1.6",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
